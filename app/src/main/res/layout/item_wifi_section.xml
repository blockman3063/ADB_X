<?xml version="1.0" encoding="utf-8"?>
<!--
    Section header for the wifi management list, e.g. "Connected" or
    "Saved networks" or "Other networks" — same look as the system
    Wi-Fi settings' grouped-list headers. We pick the style that
    matches what Android itself shows: a single line, prominent
    color, smaller text than row content, no card chrome.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="8dp"
    android:paddingTop="20dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/tvSectionTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceTitleSmall"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textStyle="bold"
        android:textAllCaps="false"
        tools:text="Saved networks" />
</FrameLayout>
